# DABAR 환경변수 예시 — 실제 값은 .env.local 에 채우세요 (git 에 올리지 않음)

# Supabase (필수)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=          # 문제 생성 스크립트 전용 (서버에서만 사용)

# Claude API (문제 생성 스크립트 전용)
ANTHROPIC_API_KEY=

# 카카오톡 공유 (선택) — https://developers.kakao.com 앱의 JavaScript 키
# 비워두면 결과 화면의 "카카오톡" 버튼은 기기 공유 시트로 대신 동작합니다.
NEXT_PUBLIC_KAKAO_JS_KEY=

# 이 파일을 복사해서 .env.local 로 저장한 뒤, 빈 값을 채우세요.
#   cp .env.local.example .env.local
# (.env.local 은 비밀이라 git 에 올라가지 않습니다. 배포 플랫폼(Vercel 등)에도 같은 값을 등록하세요.)

# ── 이미 쓰던 값 (Supabase 대시보드 → Settings → API) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<프로젝트참조>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon public 키>

# 문제 생성 스크립트용 (서버에서만 사용, 절대 공개 금지)
SUPABASE_SERVICE_KEY=<service_role 키>
ANTHROPIC_API_KEY=<앤트로픽 API 키>

# ── 이번에 추가되는 값 ──────────────────────────────────────────────
# 로그인 후 돌아올 우리 서비스 주소. 개발 중에는 http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 카카오 "공유"용 JavaScript 키 (카카오 개발자센터 → 앱 키 → JavaScript 키)
# ※ 카카오 "로그인"은 이 키가 아니라 Supabase 에 등록하는 REST API 키를 씁니다.
NEXT_PUBLIC_KAKAO_JS_KEY=
